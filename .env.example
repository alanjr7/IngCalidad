# ============================================================
# Mobile Scam Detection — Variables de Entorno
# Copiar como .env y completar los valores reales
# ============================================================

# --- Base de Datos PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=scam_detection_db
POSTGRES_USER=scam_user
POSTGRES_PASSWORD=change_me_in_production

# --- Backend / FastAPI ---
API_SECRET_KEY=change_me_super_secret_key_at_least_32_chars
API_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- ML Models ---
TEXT_MODEL_PATH=ml_models/text/bert_small_smishing.tflite
IMAGE_MODEL_PATH=ml_models/image/cnn_scam_detector.tflite
CONFIDENCE_THRESHOLD_LOW=0.4
CONFIDENCE_THRESHOLD_HIGH=0.75

# --- OCR ---
TESSERACT_PATH=/usr/bin/tesseract

# --- IA / Groq (https://console.groq.com/keys) ---
# NUNCA subas tu key real al repo. Si se filtra, revocala y generá otra.
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=playai-tts
GROQ_TTS_VOICE=Fritz-PlayAI
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=2
GROQ_MAX_OUTPUT_TOKENS=1024

# --- DigitalOcean (producción) ---
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=scam-detection-models
DO_SPACES_REGION=nyc3
